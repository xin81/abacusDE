</dependencies>


<build>
 <plugins>
 
  <plugin>
   <groupId>org.apache.maven.plugins</groupId>    	    
   <artifactId>maven-assembly-plugin</artifactId>
   <version>3.3.0</version>
   <executions>
    <execution>
     <phase>package</phase>
     <goals>
      <goal>single</goal>
     </goals>
    </execution>
   </executions>      	
      	
   <configuration>
    <finalName>abacus</finalName>
    <appendAssemblyId>false</appendAssemblyId>
    <archive>
     <manifest>
      <mainClass>abacus.Start</mainClass>
     </manifest>
    </archive>
    <descriptorRefs>
     <descriptorRef>jar-with-dependencies</descriptorRef>
    </descriptorRefs>
   </configuration>
  </plugin>
    
  <plugin>
   <artifactId>maven-resources-plugin</artifactId>
   <version>3.3.0</version>
   <executions>

    <execution>
     <id>copy-audio</id>
     <phase>process-resources</phase>
     <goals>
      <goal>copy-resources</goal>
     </goals>
     <configuration>
      <outputDirectory>${project.build.directory}/audio</outputDirectory>
      <resources>
       <resource>
        <directory>audio</directory>
        <filtering>false</filtering>
       </resource>
      </resources>
     </configuration>
    </execution>

    <execution>
     <id>copy-license</id>
     <phase>process-resources</phase>
     <goals>
      <goal>copy-resources</goal>
     </goals>
     <configuration>
      <outputDirectory>${project.build.directory}/licenses</outputDirectory>
      <resources>
       <resource>
        <directory>licenses</directory>
        <filtering>false</filtering>
       </resource>
      </resources>
     </configuration>
    </execution>
   </executions>
   </plugin>
   
