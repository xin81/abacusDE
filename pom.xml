<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>abacus</groupId><!-- com.yourname -->
  <artifactId>abacus</artifactId>
  <version>0.0.1-SNAPSHOT</version>
  <name>abacusDE</name>
  <description>Computer program version of the German abacus. You can perform maths operations by moving beads back (subtraction) and forth (addition). After each bead movement, the program displays two results, the negative and the positive result. So, unlike ordinary German abaci, this program also enables you to compute calculations with negative numbers and results. You can read the entire API documentation in section Document.
  </description>
 
 <packaging>jar</packaging>
 <properties>
<!-- suppresses irritating warnings like this one, concercing platform dependant encodings:
	Using platform encoding (UTF-8 actually) to copy filtered resources, i.e. build is platform dependent!	
	mvn clean
	mvn clean package (deletes old files and rebuilds everything)
	* mvn dependency:copy-dependencies (rarely used)
	* mvn eclipse:eclipse (old for older eclipse versions)
	mvn compile (checks if my code compiles)
	mvn compile assembly:single (most times unnecessary)
	mvn package (builds my app - includes compile + test)
	mvn install (also includes compile, test, and package)
	mvn site (almost never used in daily development)

	rule of thumb:
	while coding: mvn compile
	to build: mvn package
	if broken: mvn clean package
	if running my app: mvn exec:java
	
	mavan.compiler.release 20
-->
<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
<maven.compiler.release>26</maven.compiler.release>    	
</properties>	

<licenses>
  <license>
    <name>MIT License</name>
    <url>https://opensource.org/licenses/MIT</url>
    <distribution>repo</distribution>
    <comments>Open source permissive license</comments>
  </license>
</licenses>

