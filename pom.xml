    <artifactId>log4j-core</artifactId> 
    <!-- version>3.0.0-beta3</version -->
    <version>2.25.4</version>
    <scope>runtime</scope> 
 </dependency>

 <dependency>
  <groupId>org.junit.jupiter</groupId>
  <artifactId>junit-jupiter</artifactId>
  <version>6.0.3</version>
  <scope>test</scope>
 </dependency>

